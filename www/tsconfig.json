{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@src/*": ["../src/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "../src/node_modules", "../src/**/*"]
}
